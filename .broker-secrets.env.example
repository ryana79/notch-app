# Copy to .broker-secrets.env and fill in (never commit .broker-secrets.env)
#
# cp .broker-secrets.env.example .broker-secrets.env

# Schwab — one NotchPro app at https://developer.schwab.com
# Callback URL must be: https://127.0.0.1:8765
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# Webull — one NotchPro app at https://developer.webull.com
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Auto-generated shared key between NotchPro app and Vercel proxy (change if you want)
NOTCHPRO_BROKER_PROXY_KEY=REPLACE_WITH_openssl_rand_hex_32

# Filled automatically after deploy-broker-proxy.sh (or set manually)
SCHWAB_TOKEN_PROXY_URL=
